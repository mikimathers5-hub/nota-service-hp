# 1. Pastikan semua file sudah ada
ls -la
# Harus ada: package.json, index.html, manifest.json, service-worker.js

# 2. Install dependencies (akan membuat package-lock.json)
npm install

# 3. Verifikasi package-lock.json terbuat
ls package-lock.json

# 4. Commit semua file
git add package.json
git add package-lock.json
git add .github/workflows/build-apk.yml
git add .github/scripts/update_manifest.py
git commit -m "Setup GitHub Actions with package-lock.json for CI caching"
git push origin main
